@modules
[
    (
        id: "gi_usart_1",
        kind: GenericInterfaceUsart,
        name: "GI_USART1",
        pos: (0.0, 0.0),
        config: Usart((
            instance: 1,
            baud_rate: 115200,
            data_bits: 8,
            parity: None,
            stop_bits: One,
            rx_model: "",
            tx_model: "",
            custom_label: "mw radar",
        )),
        connections: [
            (
                signal: Tx,
                mcu_pin: 30,
            ),
            (
                signal: Rx,
                mcu_pin: 31,
            ),
        ],
    ),
    (
        id: "gi_i2c_2",
        kind: GenericInterfaceI2c,
        name: "GI_I2C1",
        pos: (0.0, 0.0),
        config: I2c((
            instance: 1,
            clock_hz: 400000,
            address: 0,
            rx_model: "",
            tx_model: "",
            custom_label: "128x32 display",
        )),
        connections: [
            (
                signal: Scl,
                mcu_pin: 45,
            ),
            (
                signal: Sda,
                mcu_pin: 46,
            ),
        ],
    ),
]

@clock
hse=8000000
hse_on=1
src=pll
pll=hse
mul=9
ahb=1
apb1=2
apb2=1
adc=6
usb=1_5
mco=none
rtc=lsi
systick=hclk8
css=0

@structure_layout
{
    "menu_navigator/mod.rs": (14.0, 351.40997),
    "menu_navigator/rotary_encoder.rs": (14.0, 230.68373),
    "mw_radar/data.rs": (317.70798, 518.21375),
    "mw_radar/mod.rs": (265.7168, 680.55566),
    "mw_radar/radar.rs": (437.78717, 771.4389),
    "mw_radar/read.rs": (14.0, 519.37665),
    "mw_radar/read_param.rs": (454.7858, 515.00574),
    "mw_radar/read_report.rs": (189.81583, 521.35815),
    "mw_radar/send_models.rs": (21.884205, 752.2365),
    "pins/configs/i2c1.rs": (253.64691, 191.71384),
    "pins/configs/mod.rs": (204.7341, 111.80455),
    "pins/configs/usart1.rs": (142.86479, 196.01859),
    "pins/mod.rs": (349.2047, 48.696125),
    "pins/utils/gpio_out.rs": (636.7984, 195.32687),
    "pins/utils/i2c1.rs": (407.24744, 198.5419),
    "pins/utils/mod.rs": (538.9751, 117.63963),
}
